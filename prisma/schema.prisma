// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// DS3 World & Store Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===================
// NEXTAUTH MODELS
// ===================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ===================
// USER & COMMUNITY MODELS
// ===================

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  username      String   @unique
  role          UserRole @default(USER)
  loyaltyPoints Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  orders        Order[]
  cartItems     CartItem[]

  @@map("users")
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  avatarUrl String?
  bio       String?
  guildRank GuildRank @default(NOVICE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

// ===================
// E-COMMERCE & INVENTORY MODELS
// ===================

model BoxTheme {
  id          String  @id @default(cuid())
  name        String
  description String
  price       Decimal @db.Decimal(10, 2)
  imageUrl    String?
  isActive    Boolean @default(true)
  isSoldOut   Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  boxItemMappings BoxItemMapping[]
  orderLineItems OrderLineItem[]
  cartItems      CartItem[]

  @@map("box_themes")
}

model Item {
  id           String     @id @default(cuid())
  name         String
  sku          String     @unique
  stockQuantity Int       @default(0)
  costPrice    Decimal    @db.Decimal(10, 2)
  rarityTier   RarityTier
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  boxItemMappings BoxItemMapping[]

  @@map("items")
}

// ===================
// MYSTERY BOX LOGIC (CRUCIAL)
// ===================

model BoxItemMapping {
  id          String  @id @default(cuid())
  boxThemeId  String
  itemId      String
  dropChance  Float   // Percentage chance (0.0 to 100.0)
  isGuaranteed Boolean @default(false)
  createdAt   DateTime @default(now())

  // Relations
  boxTheme BoxTheme @relation(fields: [boxThemeId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([boxThemeId, itemId])
  @@map("box_item_mappings")
}

// ===================
// ORDERS & TRANSACTIONS
// ===================

model Order {
  id             String      @id @default(cuid())
  userId         String
  totalAmount    Decimal     @db.Decimal(10, 2)
  status         OrderStatus @default(PENDING)
  shippingAddress Json       // Address information
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  user          User            @relation(fields: [userId], references: [id])
  orderLineItems OrderLineItem[]

  @@map("orders")
}

model OrderLineItem {
  id         String @id @default(cuid())
  orderId    String
  boxThemeId String
  rolledItems Json   // Array of Item IDs that were rolled for this specific box
  createdAt  DateTime @default(now())

  // Relations
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  boxTheme BoxTheme @relation(fields: [boxThemeId], references: [id])

  @@map("order_line_items")
}

// ===================
// SHOPPING CART (Bonus for better UX)
// ===================

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  boxThemeId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  boxTheme BoxTheme @relation(fields: [boxThemeId], references: [id], onDelete: Cascade)

  @@unique([userId, boxThemeId])
  @@map("cart_items")
}

// ===================
// ENUMS
// ===================

enum UserRole {
  ADMIN
  USER
}

enum GuildRank {
  NOVICE
  APPRENTICE
  TREASURE_HUNTER
  MASTER_COLLECTOR
  LEGENDARY
}

enum RarityTier {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ===================
// DROPSHIPPING & SUPPLIER MODELS
// ===================

enum SupplierType {
  DEODAP
  INDIAMART
  UDAAN
  MEESHO
  CUSTOM
}

enum ProductType {
  MYSTERY_BOX
  ACCESSORY
  TOY
  GENERAL
}

model Supplier {
  id              String       @id @default(cuid())
  name            String
  type            SupplierType
  apiKey          String?
  apiSecret       String?
  webhookUrl      String?
  isActive        Boolean      @default(true)
  contactEmail    String?
  contactPhone    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  products        SupplierProduct[]
  dropshipOrders  DropshipOrder[]

  @@map("suppliers")
}

model SupplierProduct {
  id              String       @id @default(cuid())
  supplierId      String
  supplierSku     String
  name            String
  description     String?
  category        String?
  wholesalePrice  Decimal      @db.Decimal(10, 2)
  retailPrice     Decimal      @db.Decimal(10, 2)
  stockQuantity   Int          @default(0)
  minOrderQty     Int          @default(1)
  weight          Float?        // in grams
  dimensions      String?      // JSON string for LxWxH
  imageUrl        String?
  isActive        Boolean      @default(true)
  lastSyncAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  supplier        Supplier     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  dropshipItems   DropshipOrderItem[]

  @@unique([supplierId, supplierSku])
  @@map("supplier_products")
}

model DropshipOrder {
  id              String       @id @default(cuid())
  orderId         String       // References our main Order table
  supplierId      String
  supplierOrderId  String?      // Order ID from supplier system
  supplierStatus   String?      // Status from supplier
  trackingNumber  String?
  totalAmount     Decimal      @db.Decimal(10, 2)
  shippingCost    Decimal      @db.Decimal(10, 2) @default(0)
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress Json          // JSON object for address
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  supplier        Supplier     @relation(fields: [supplierId], references: [id])
  items           DropshipOrderItem[]

  @@map("dropship_orders")
}

model DropshipOrderItem {
  id                String   @id @default(cuid())
  dropshipOrderId    String
  supplierProductId  String
  quantity          Int
  unitPrice         Decimal  @db.Decimal(10, 2)
  totalPrice        Decimal  @db.Decimal(10, 2)

  // Relations
  dropshipOrder     DropshipOrder @relation(fields: [dropshipOrderId], references: [id], onDelete: Cascade)
  supplierProduct   SupplierProduct @relation(fields: [supplierProductId], references: [id])

  @@map("dropship_order_items")
}
